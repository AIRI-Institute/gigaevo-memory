# === PostgreSQL ===
POSTGRES_USER=memory
POSTGRES_PASSWORD=memory_dev_password
POSTGRES_DB=memory
POSTGRES_DSN=postgresql+asyncpg://memory:memory_dev_password@postgres:5432/memory

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === API ===
API_SECRET_KEY=dev-secret-key-change-in-production
API_HOST=0.0.0.0
API_PORT=8000
MEMORY_API_HOST_PORT=8002
MEMORY_WEB_UI_HOST_PORT=7861

# === Feature Flags ===
ENABLE_VECTOR_SEARCH=false
VECTOR_DIMENSION=384
ENABLE_OPENSEARCH=false
ENABLE_MINIO=false
